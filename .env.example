# Prefer a single URL:
DATABASE_URL=postgresql://user:password@localhost:5432/gestor_db

# Or omit DATABASE_URL and set legacy vars (built as postgresql://USER:PASSWORD@localhost:5432/gestor_db):
# USER=postgres
# PASSWORD=secret

SECRET_KEY=replace_with_a_secure_random_key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
